+
+static void report_dispatched_instruction_count(void)
+{
+  if (report_instruction_count) {
+    glui32 opcode;
+
+    fprintf(stderr, "GLULXE_INSTRUCTION_COUNT=%" PRIu64 "\n",
+      glulx_dispatched_instruction_count);
+    if (glulx_report_opcode_histogram) {
+      for (opcode = 0; opcode < GLULXE_OPCODE_TABLE_SIZE; opcode++) {
+        if (glulx_opcode_counts[opcode]) {
+          fprintf(stderr, "GLULXE_OPCODE_COUNT_0x%03X=%" PRIu64 "\n",
+            opcode, glulx_opcode_counts[opcode]);
+        }
+      }
+    }
+    fflush(stderr);
+  }
+}
