! Former fixed limits of the direct-IR path, now dynamic. Every routine
! here exceeds one of the old caps and must still build direct IR with
! zero fallbacks, matching the classic backend's transcript exactly:
!  - DeepStack: 70 pending @push values (old symbolic-stack cap: 64).
!  - CallMany: a 40-argument call (old call-arity cap: 32).
!  - DeepSwitch: 35 nested switch statements (old nesting cap: 32).
!  - SlotPressure: one call whose 300 arguments are all live computed
!    temporaries, forcing a >250-slot frame emitted with a multi-pair
!    Glulx locals format (old lowerer cap: 250, one format pair).

[ DeepStack x total;
    total = 0;
    x = 1; @push x;
    x = 2; @push x;
    x = 3; @push x;
    x = 4; @push x;
    x = 5; @push x;
    x = 6; @push x;
    x = 7; @push x;
    x = 8; @push x;
    x = 9; @push x;
    x = 10; @push x;
    x = 11; @push x;
    x = 12; @push x;
    x = 13; @push x;
    x = 14; @push x;
    x = 15; @push x;
    x = 16; @push x;
    x = 17; @push x;
    x = 18; @push x;
    x = 19; @push x;
    x = 20; @push x;
    x = 21; @push x;
    x = 22; @push x;
    x = 23; @push x;
    x = 24; @push x;
    x = 25; @push x;
    x = 26; @push x;
    x = 27; @push x;
    x = 28; @push x;
    x = 29; @push x;
    x = 30; @push x;
    x = 31; @push x;
    x = 32; @push x;
    x = 33; @push x;
    x = 34; @push x;
    x = 35; @push x;
    x = 36; @push x;
    x = 37; @push x;
    x = 38; @push x;
    x = 39; @push x;
    x = 40; @push x;
    x = 41; @push x;
    x = 42; @push x;
    x = 43; @push x;
    x = 44; @push x;
    x = 45; @push x;
    x = 46; @push x;
    x = 47; @push x;
    x = 48; @push x;
    x = 49; @push x;
    x = 50; @push x;
    x = 51; @push x;
    x = 52; @push x;
    x = 53; @push x;
    x = 54; @push x;
    x = 55; @push x;
    x = 56; @push x;
    x = 57; @push x;
    x = 58; @push x;
    x = 59; @push x;
    x = 60; @push x;
    x = 61; @push x;
    x = 62; @push x;
    x = 63; @push x;
    x = 64; @push x;
    x = 65; @push x;
    x = 66; @push x;
    x = 67; @push x;
    x = 68; @push x;
    x = 69; @push x;
    x = 70; @push x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
    @pull x; total = total + x;
