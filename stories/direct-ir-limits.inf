[ Main win dummy;
    @setiosys 2 0;
    ! glk_window_open(0, 0, 0, 3, 0), args pushed in reverse
    @copy 0 sp; @copy 3 sp; @copy 0 sp; @copy 0 sp; @copy 0 sp;
    @glk $0023 5 win;
    @copy win sp;
    @glk $002F 1 dummy;    ! glk_set_window
    print "deepstack=", DeepStack(), "^";
    print "callmany=", CallMany(), "^";
    print "deepswitch=", DeepSwitch(5), "^";
    print "slotpressure=", SlotPressure(1, 2), "^";
];
